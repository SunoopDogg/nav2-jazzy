<?xml version="1.0"?>
<robot name="go2">

  <!-- Virtual ground-contact origin; AMCL localizes this frame -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.33" rpy="0 0 0"/>
  </joint>

  <!-- Body: real Go2 trunk mesh; box collision kept simple for nav2 footprint -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="0.1303" ixy="0" ixz="0" iyy="0.5383" iyz="0" izz="0.6483"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nav2_custom_worlds/models/go2/meshes/base.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.65 0.31 0.09"/></geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.285 0 0.048" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.04" /></geometry>
      <material name="lidar_blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ===== Legs: visual-only, frozen at standing pose (hip0, thigh+0.9, calf-1.8) ===== -->

  <!-- Front-Left -->
  <joint name="FL_hip_joint" type="fixed"><parent link="base_link"/><child link="FL_hip"/><origin xyz="0.1934 0.0465 0" rpy="0 0 0"/></joint>
  <link name="FL_hip"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/hip.dae"/></geometry></visual></link>
  <joint name="FL_thigh_joint" type="fixed"><parent link="FL_hip"/><child link="FL_thigh"/><origin xyz="0 0.0955 0" rpy="0 0.9 0"/></joint>
  <link name="FL_thigh"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/thigh.dae"/></geometry></visual></link>
  <joint name="FL_calf_joint" type="fixed"><parent link="FL_thigh"/><child link="FL_calf"/><origin xyz="0 0 -0.213" rpy="0 -1.8 0"/></joint>
  <link name="FL_calf"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/calf.dae"/></geometry></visual></link>
  <joint name="FL_foot_joint" type="fixed"><parent link="FL_calf"/><child link="FL_foot"/><origin xyz="0 0 -0.213" rpy="0 0 0"/></joint>
  <link name="FL_foot"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/foot.dae"/></geometry></visual></link>

  <!-- Front-Right -->
  <joint name="FR_hip_joint" type="fixed"><parent link="base_link"/><child link="FR_hip"/><origin xyz="0.1934 -0.0465 0" rpy="0 0 0"/></joint>
  <link name="FR_hip"><visual><origin xyz="0 0 0" rpy="3.1415 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/hip.dae"/></geometry></visual></link>
  <joint name="FR_thigh_joint" type="fixed"><parent link="FR_hip"/><child link="FR_thigh"/><origin xyz="0 -0.0955 0" rpy="0 0.9 0"/></joint>
  <link name="FR_thigh"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/thigh_mirror.dae"/></geometry></visual></link>
  <joint name="FR_calf_joint" type="fixed"><parent link="FR_thigh"/><child link="FR_calf"/><origin xyz="0 0 -0.213" rpy="0 -1.8 0"/></joint>
  <link name="FR_calf"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/calf_mirror.dae"/></geometry></visual></link>
  <joint name="FR_foot_joint" type="fixed"><parent link="FR_calf"/><child link="FR_foot"/><origin xyz="0 0 -0.213" rpy="0 0 0"/></joint>
  <link name="FR_foot"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/foot.dae"/></geometry></visual></link>

  <!-- Rear-Left -->
  <joint name="RL_hip_joint" type="fixed"><parent link="base_link"/><child link="RL_hip"/><origin xyz="-0.1934 0.0465 0" rpy="0 0 0"/></joint>
  <link name="RL_hip"><visual><origin xyz="0 0 0" rpy="0 3.1415 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/hip.dae"/></geometry></visual></link>
  <joint name="RL_thigh_joint" type="fixed"><parent link="RL_hip"/><child link="RL_thigh"/><origin xyz="0 0.0955 0" rpy="0 0.9 0"/></joint>
  <link name="RL_thigh"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/thigh.dae"/></geometry></visual></link>
  <joint name="RL_calf_joint" type="fixed"><parent link="RL_thigh"/><child link="RL_calf"/><origin xyz="0 0 -0.213" rpy="0 -1.8 0"/></joint>
  <link name="RL_calf"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/calf.dae"/></geometry></visual></link>
  <joint name="RL_foot_joint" type="fixed"><parent link="RL_calf"/><child link="RL_foot"/><origin xyz="0 0 -0.213" rpy="0 0 0"/></joint>
  <link name="RL_foot"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/foot.dae"/></geometry></visual></link>

  <!-- Rear-Right -->
  <joint name="RR_hip_joint" type="fixed"><parent link="base_link"/><child link="RR_hip"/><origin xyz="-0.1934 -0.0465 0" rpy="0 0 0"/></joint>
  <link name="RR_hip"><visual><origin xyz="0 0 0" rpy="3.1415 3.1415 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/hip.dae"/></geometry></visual></link>
  <joint name="RR_thigh_joint" type="fixed"><parent link="RR_hip"/><child link="RR_thigh"/><origin xyz="0 -0.0955 0" rpy="0 0.9 0"/></joint>
  <link name="RR_thigh"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/thigh_mirror.dae"/></geometry></visual></link>
  <joint name="RR_calf_joint" type="fixed"><parent link="RR_thigh"/><child link="RR_calf"/><origin xyz="0 0 -0.213" rpy="0 -1.8 0"/></joint>
  <link name="RR_calf"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/calf_mirror.dae"/></geometry></visual></link>
  <joint name="RR_foot_joint" type="fixed"><parent link="RR_calf"/><child link="RR_foot"/><origin xyz="0 0 -0.213" rpy="0 0 0"/></joint>
  <link name="RR_foot"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://nav2_custom_worlds/models/go2/meshes/foot.dae"/></geometry></visual></link>

</robot>
